# ── Required ──────────────────────────────────────────
OPENAI_API_KEY=

# ── Auth (required for owner access) ─────────────────
# Secret used for signing auth cookies (HMAC-SHA256)
APP_SECRET=your-secret-here
# Password to log in as owner
APP_PASSWORD=your-password-here

# ── Recommended ──────────────────────────────────────
# TMDB — real movie/TV posters and screencaps (free)
# Get yours at https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# ── Optional: YouTube ────────────────────────────────
# YouTube Data API key (for video search)
# Enable at Google Cloud Console > APIs > YouTube Data API v3
YOUTUBE_API_KEY=

# Google OAuth (for importing liked videos + subscriptions)
# Google Cloud Console > Credentials > OAuth 2.0 Client ID
# Add redirect URI: https://your-domain/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Optional: MyAnimeList ────────────────────────────
# Official MAL API (falls back to Jikan if not set)
# Create at https://myanimelist.net/apiconfig
MAL_CLIENT_ID=

# ── Optional: Substack ──────────────────────────────
# Brave Search API (for finding real Substack articles)
# Get yours at https://brave.com/search/api/
BRAVE_API_KEY=

# ── Production (optional) ────────────────────────────
# Only needed if deploying to Vercel. Local dev uses SQLite.
# TURSO_DATABASE_URL=
# TURSO_AUTH_TOKEN=
# NEXT_PUBLIC_BASE_URL=
