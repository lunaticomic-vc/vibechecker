OPENAI_API_KEY=your_key_here
YOUTUBE_API_KEY=your_key_here

# Turso Database (for production/Vercel)
# 1. Install Turso CLI: curl -sSfL https://get.tur.so/install.sh | bash
# 2. turso auth signup (or login)
# 3. turso db create vibechecker
# 4. turso db show vibechecker --url → paste as TURSO_DATABASE_URL
# 5. turso db tokens create vibechecker → paste as TURSO_AUTH_TOKEN
# Leave blank for local development (uses local SQLite file)
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Google OAuth (for YouTube import)
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Create OAuth 2.0 Client ID (Web application)
# 3. Add authorized redirect URI: http://localhost:3000/api/auth/google/callback
# 4. Enable "YouTube Data API v3" in APIs & Services > Library
# MyAnimeList API (optional - falls back to Jikan if not set)
# Create at https://myanimelist.net/apiconfig
MAL_CLIENT_ID=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Base URL (set for production, e.g., https://vibechecker.vercel.app)
NEXT_PUBLIC_BASE_URL=
